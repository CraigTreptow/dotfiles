# https://stackoverflow.com/a/55171807/329921
# killport <port>
function killport () {
  readonly port=${1:?"The port must be specified."}
  # Try graceful shutdown first, then force kill if needed
  local pids=$(lsof -i tcp:"$port" | grep LISTEN | awk '{print $2}')
  if [ -n "$pids" ]; then
    echo "$pids" | xargs kill 2>/dev/null || echo "$pids" | xargs kill -9
  fi
}

