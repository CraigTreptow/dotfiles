# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms
command = /usr/bin/zsh

# Simple Alt+Shift+Arrow resizing
keybind = alt+shift+up=resize_split:up,10
keybind = alt+shift+down=resize_split:down,10
keybind = alt+shift+left=resize_split:left,10
keybind = alt+shift+right=resize_split:right,10

# ============================================================================
# Custom Configuration - Retro Terminal Green Theme
# ============================================================================

# Window Focus Settings
# Dim unfocused split panes to 50% opacity for clear visual distinction
unfocused-split-opacity = 0.5

# Split divider - Limegreen border matching website aesthetic
split-divider-color = #32CD32

# Color Scheme - Retro Terminal Green Theme
# Base colors - black background, white text
background = #000000
foreground = #ffffff

# Cursor - bright green for visibility
cursor-color = #00ff00

# Selection - blue (matching website)
selection-background = #0080ff
selection-foreground = #ffffff

# ANSI Colors - Terminal Palette with Green Accents
# Black
palette = 0=#000000
palette = 8=#555555

# Red
palette = 1=#ff0000
palette = 9=#ff5555

# Green - Bold limegreen theme
palette = 2=#00ff00
palette = 10=#00ff00

# Yellow
palette = 3=#ffff00
palette = 11=#ffff00

# Blue
palette = 4=#0080ff
palette = 12=#5555ff

# Magenta
palette = 5=#ff00ff
palette = 13=#ff55ff

# Cyan
palette = 6=#00ffff
palette = 14=#55ffff

# White
palette = 7=#bbbbbb
palette = 15=#ffffff

# Font Settings
# Match website's Inconsolata font (if installed)
font-family = Inconsolata
font-size = 13
