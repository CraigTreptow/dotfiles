# Copy this file to ~/.zshrc.secrets and fill in real values
# cp ~/dotfiles/zshrc-work.secrets.example ~/.zshrc.secrets
# chmod 600 ~/.zshrc.secrets

export STAGING_API_KEY="your_staging_api_key_here"
export SECRET_KEY_BASE="your_secret_key_base_here"

# GitHub (required for /release-notes command)
export GITHUB_PERSONAL_ACCESS_TOKEN="github_pat_XXXXXXXXXXXXXXXXXXXX"

# Zendesk (get token from 1Password: "Zendesk MCP API Token")
export ZENDESK_DOMAIN="mbc1.zendesk.com"
export ZENDESK_EMAIL="you@merchantsbonding.com"
export ZENDESK_API_TOKE="your_zendesk_api_token_here"

# Notion (get from https://www.notion.so/my-integrations)
export NOTION_API_KEY="ntn_XXXXXXXXXXXXXXXXXXXX"

# Sentry (get from https://sentry.io/settings/account/api/auth-tokens/)
export SENTRY_ORG="merchants-bonding-company"
export SENTRY_AUTH_TOKEN="sntryu_XXXXXXXXXXXXXXXXXXXX"
