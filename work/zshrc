# Set personal aliases, overriding those provided by oh-my-zsh libs,
# plugins, and themes. Aliases can be placed here, though oh-my-zsh
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
####################  Aliases  ####################
alias vim=nvim
alias ccusage="~/.bun/bin/ccusage"
alias cat="bat"
alias grep="rg"
alias be="bundle exec"

# Overmind process groups
# Usage: om-web, om-jobs, om-karafka, om-listeners, om-all, om-core
# Connect: omc-web <process>, omc-jobs <process>, etc.
# Stop: omq-web, omq-jobs, omq-all, or omq (stops all groups)
om-web()       { cd ~/workspace/mbc && OVERMIND_ENV=~/workspace/.overmind-web.env       overmind s -D -s ~/workspace/.overmind-web.sock; }
om-jobs()      { cd ~/workspace/mbc && OVERMIND_ENV=~/workspace/.overmind-jobs.env      overmind s -D -s ~/workspace/.overmind-jobs.sock; }
om-karafka()   { cd ~/workspace/mbc && OVERMIND_ENV=~/workspace/.overmind-karafka.env   overmind s -D -s ~/workspace/.overmind-karafka.sock; }
om-listeners() { cd ~/workspace/mbc && OVERMIND_ENV=~/workspace/.overmind-listeners.env overmind s -D -s ~/workspace/.overmind-listeners.sock; }
om-core()      { cd ~/workspace/mbc && OVERMIND_ENV=~/workspace/.overmind-core.env      overmind s -D -s ~/workspace/.overmind-core.sock; }
om-all()       { cd ~/workspace/mbc && OVERMIND_ENV=~/workspace/.overmind-all.env       overmind s -D -s ~/workspace/.overmind-all.sock; }

# Overmind connect helpers
omc-web() { overmind c -s ~/workspace/.overmind-web.sock "$1"; }
omc-jobs() { overmind c -s ~/workspace/.overmind-jobs.sock "$1"; }
omc-karafka() { overmind c -s ~/workspace/.overmind-karafka.sock "$1"; }
omc-listeners() { overmind c -s ~/workspace/.overmind-listeners.sock "$1"; }
omc-core() { overmind c -s ~/workspace/.overmind-core.sock "$1"; }
omc-all() { overmind c -s ~/workspace/.overmind-all.sock "$1"; }

# Overmind quit helpers
omq-web() { overmind q -s ~/workspace/.overmind-web.sock; }
omq-jobs() { overmind q -s ~/workspace/.overmind-jobs.sock; }
omq-karafka() { overmind q -s ~/workspace/.overmind-karafka.sock; }
omq-listeners() { overmind q -s ~/workspace/.overmind-listeners.sock; }
omq-core() { overmind q -s ~/workspace/.overmind-core.sock; }
omq-all() { overmind q -s ~/workspace/.overmind-all.sock; }
omq() { for s in ~/workspace/.overmind-*.sock; do [ -e "$s" ] && overmind q -s "$s"; done; }

